# Configurações da API
HOST = 0.0.0.0 # ip de execução, no caso em todos os ips
PORT = 8000
RELOAD = True # True ou ''
# Configurações banco de dados
DB_SGDB = sqlite # sqlite - SQLite, mysql - MySQL, mssql - SQL Server
DB_NAME = comandas_db
# Caso seja diferente de sqlite
DB_HOST = 127.0.0.1 # :3306 :5432
DB_USER = coelho
DB_PASS = abcBolinhas12345
# Configurações Segurança da API - JWT
# Para obter uma cadeia de caracteres execute no gitbash: openssl rand -hex 32
# Ou crie uma chave secreta super forte, devendo mudar em produção
# Não utilize a do exemplo!
SECRET_KEY = suaChaveMuitoForte
ALGORITHM = HS256
ACCESS_TOKEN_EXPIRE_MINUTES = 600
REFRESH_TOKEN_EXPIRE_DAYS = 7
# Configurações de Rate Limiting
# Muito restritivo - Login, refresh, logout, exclusões, operações sensíveis
RATE_LIMIT_CRITICAL = 5/minute
# Restritivo - Criações, atualizações, exclusões de dados
RATE_LIMIT_RESTRICTIVE = 20/minute
# Moderado - Listagens, buscas por ID, auditoria
RATE_LIMIT_MODERATE = 100/minute
# Baixo - Health checks, endpoints de sistema, documentos
RATE_LIMIT_LOW = 200/minute
# Leve - Endpoints públicos, documentação
RATE_LIMIT_LIGHT = 300/minute
# Padrão para endpoints não especificados
RATE_LIMIT_DEFAULT = 50/minute
# Configuração de CORS
# Domínios permitidos separados por vírgula. Ex: http://localhost:3000,http://localhost:5173
# Para permitir todos temporariamente no dev, use *
CORS_ORIGINS=*